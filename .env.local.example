# Local development — copy to .env.local
APP_ENV=development
MOCK_LLM=true
ALLOW_DEV_AUTH=true
APP_SECRET_KEY=local-dev-secret-not-for-production

DATABASE_URL=postgresql+asyncpg://acf:acf@localhost:5432/ai_content_factory
REDIS_URL=redis://localhost:6379/0

# Optional: leave blank to use dev auth bypass (no Clerk dashboard activity)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=

GOOGLE_API_KEY=
GROQ_API_KEY=
USE_LITELLM_PROXY=false
LITELLM_PROXY_URL=http://localhost:4000

VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-content-factory
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
RUN_MIGRATIONS_ON_STARTUP=false
LOG_JSON=false
