# ── App ──────────────────────────────────────────────
APP_ENV=development
MOCK_LLM=true
APP_SECRET_KEY=change-me-in-production
API_BASE_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://acf:acf@localhost:5432/ai_content_factory

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Clerk) ─────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM Providers (Free-first) ───────────────────────
GOOGLE_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_PROXY_URL=http://localhost:4000
# Set true only when the LiteLLM docker service is running
USE_LITELLM_PROXY=false

# ── Vector DB ────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=acf-research
# Or use local Qdrant:
QDRANT_URL=http://localhost:6333

# ── Object Storage (Cloudflare R2) ───────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=acf-media
R2_PUBLIC_URL=

# ── Observability ────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-content-factory
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Platform OAuth (publish targets) ─────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MEDIUM_INTEGRATION_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
SUBSTACK_API_KEY=
