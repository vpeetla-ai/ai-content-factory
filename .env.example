# ═══════════════════════════════════════════════════════════════
# AI Content Factory — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# LOCAL:  copy to .env.local   (APP_ENV=development)
# PROD:   copy to .env.production (APP_ENV=production) — set in hosting dashboard
#
# See docs/DEPLOYMENT.md for full cloud setup guide.
# ═══════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────
APP_ENV=development
MOCK_LLM=true
APP_SECRET_KEY=change-me-in-production-min-32-chars
API_BASE_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://acf:acf@localhost:5432/ai_content_factory

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Clerk) ─────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
ALLOW_DEV_AUTH=true

# ── LLM Providers ────────────────────────────────────────────
GOOGLE_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-acf-dev
USE_LITELLM_PROXY=false

# ── Vector DB ────────────────────────────────────────────────
# local: qdrant via docker | prod: qdrant cloud or pinecone
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=acf_research
PINECONE_API_KEY=
PINECONE_INDEX=acf-research
PINECONE_ENVIRONMENT=us-east-1
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── Object Storage (Cloudflare R2) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=acf-media
R2_PUBLIC_URL=

# ── Observability ────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-content-factory
LANGSMITH_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
LOG_JSON=false

# ── Platform OAuth ───────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MEDIUM_INTEGRATION_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Ops ──────────────────────────────────────────────────────
RUN_MIGRATIONS_ON_STARTUP=false
PORT=8000
WORKERS=2
