# Production — set these in Render/Railway dashboard (do NOT commit real values)
APP_ENV=production
MOCK_LLM=false
ALLOW_DEV_AUTH=false
APP_SECRET_KEY=<generate-with-openssl-rand-hex-32>

# Neon Postgres (free tier)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/ai_content_factory?sslmode=require

# Upstash Redis (free tier)
REDIS_URL=rediss://default:token@xxx.upstash.io:6379

# Clerk (production instance)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# LLM keys
GOOGLE_API_KEY=
GROQ_API_KEY=
USE_LITELLM_PROXY=false

# Vector — Qdrant Cloud free cluster OR Pinecone starter
VECTOR_BACKEND=qdrant
QDRANT_URL=https://xxx.cloud.qdrant.io:6333
QDRANT_API_KEY=
# OR:
# VECTOR_BACKEND=pinecone
# PINECONE_API_KEY=
# PINECONE_INDEX=acf-research

# Observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-content-factory
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
SENTRY_DSN=

# URLs (set after deploy)
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGINS=https://your-app.vercel.app
API_BASE_URL=https://your-api.onrender.com/api/v1

RUN_MIGRATIONS_ON_STARTUP=true
LOG_JSON=true
WORKERS=2
